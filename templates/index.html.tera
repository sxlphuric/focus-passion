<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Task manager</title>
        <link rel="stylesheet" href="/style.css">
        <script src="https://unpkg.com/htmx.org@1.9.10"></script>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    </head>
    <body>
        <h1>Task manager</h1>
        <div class="new-task">
            <form hx-post="/tasks/add" hx-target="#task-list" hx-swap="beforeend" hx-on::after-request="this.reset()" class="new-task">
                <div class="new-int-">
                <input type="text" name="name" class="new-int" placeholder="Task" required />
                <input type="text" name="project" class="new-int" placeholder="Project" list="project-dropdown" reqiored />
                <datalist class="new-int" id="project-dropdown">
                    {% for project in projects %}
                    <option value="{{project}}">
                    {%endfor%}
                </datalist>
                <textarea name="description" placeholder="Description" class="new-int"></textarea>
                <button type="submit" class="new-int">Add</button>
                </div>
            </form>
        </div>
        <div class="tasks-list">
            <h2>Tasks</h2>
            <ul id="task-list" class="task-list">
            {% for task in tasks %}
                {% include "task_item" %}
            {% else %}
                <li id="empty-message">Whew! No tasks!</li>
            {% endfor %}
            </ul>
        </div>
    </body>
</html>
