<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Task manager</title>
        <link rel="stylesheet" href="/style.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
        <script src="https://unpkg.com/htmx.org@1.9.10"></script>
        <script defer src="https://unpkg.com/alpinejs@3.15.11/dist/cdn.min.js"></script>
        <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
    </head>
    <body>
        <div id="modal-portal"></div>
        <h1>Task manager</h1>
        {% include "new_task" %}
        <div class="task-list-container">
            <h2>Tasks</h2>
            <div class="tabs-row">
                <button x-on:click="activeTab = 'pending'; newTaskNotification=false;" :class="{ 'active': activeTab === 'pending', 'task-notification': newTaskNotification }" class="tab-button" hx-get="/tasks/list" hx-target="#task-list" hx-swap="outerHTML">Pending</button>
                        <button x-on:click="activeTab = 'completed'" :class="{ 'active': activeTab === 'completed' }" class="tab-button" hx-get="/tasks/list?status=completed" hx-target="#task-list" hx-swap="outerHTML">Completed</button>
            </div>
                        <ul id="task-list" class="task-list">
            {% for task in tasks %}
                {% include "task_item" %}
            {% endfor %}
                <li id="empty-message">Whew! No tasks!</li>
            </ul>
        </div>
    </body>
</html>
